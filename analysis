
-- STEP 4: BUSINESS ABALYSIS QUESTIONS

--------------------------------------------------------------------------------------------------------------------------------------------------
--1. Find the number of business in each unique category.
--------------------------------------------------------------------------------------------------------------------------------------------------
select category, count(distinct business_id) as no_of_businesses
from yelp_business_categories
group by 1
order by 2 desc;

--------------------------------------------------------------------------------------------------------------------------------------------------
--2. Find the top 10 users who have reviewed the most businesses in the 'Restuarants' category.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Using yelp_business_categories to avoid repeated lateral split_to_table
select 
    r.user_id,
    count(distinct r.business_id) as businesses_reviewed
from yelp_reviews_table r
inner join yelp_business_categories bc
    on r.business_id = bc.business_id
where bc.category ilike '%restaurant%'
and r.user_id is not null  -- excluding null user_ids due to upstream data quality issues
group by 1
order by 2 desc
limit 10;

--NOTE:
--I noticed a NULL user_id group with a large count, which suggests missing or incomplete user identifiers. 
--I would exclude those for user-level analysis or investigate upstream data quality issues.

--------------------------------------------------------------------------------------------------------------------------------------------------
--3. Find the most popular categories of businesses (based on the max number of reviews and not the number of stars); top 20.
--------------------------------------------------------------------------------------------------------------------------------------------------
select 
    bc.category,
    count(*) as total_reviews
from yelp_reviews_table r
inner join yelp_business_categories bc
    on r.business_id = bc.business_id
group by 1
order by 2 desc
limit 20;


--------------------------------------------------------------------------------------------------------------------------------------------------
--4. Find the top 3 most recent reviews for each business.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Using row_number() with tiebreaker on user_id for deterministic ordering
with ranked_reviews as (
    select 
        business_id,
        business_name,
        user_id,
        review_stars,
        review_date,
        row_number() over (
            partition by business_id 
            order by review_date desc, user_id
        ) as review_rank
    from yelp_reviews_enriched
    where user_id is not null
)
select 
    business_id,
    business_name,
    user_id,
    review_stars,
    review_date,
    review_rank
from ranked_reviews
where review_rank <= 3
order by business_id, review_rank;

--------------------------------------------------------------------------------------------------------------------------------------------------
--5. Find the month with highest number of reviews.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Includes month number for correct calendar ordering
select 
    month(review_date) as month_number,
    trim(to_varchar(review_date, 'MMMM')) as review_month,
    count(*) as review_count
from yelp_reviews_enriched
where review_date is not null
group by 1, 2
order by 3 desc;

--------------------------------------------------------------------------------------------------------------------------------------------------
--6. Find the percentage of 5-star reviews for each business.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Filtered to businesses with at least 10 reviews to avoid misleading percentages
select 
    business_id,
    business_name,
    count(*) as total_reviews,
    sum(case when review_stars = 5 then 1 else 0 end) as five_star_reviews,
    round(sum(case when review_stars = 5 then 1 else 0 end) * 100.0 / count(*), 2) as pct_5_star_reviews
from yelp_reviews_enriched
group by 1, 2
-- Minimum 10 reviews required; threshold can be adjusted based on business context
having count(*) >= 10
order by pct_5_star_reviews desc
limit 50; -- practical output size

--------------------------------------------------------------------------------------------------------------------------------------------------
--7. Find the top 5 most reviewed businesses in each city.
--------------------------------------------------------------------------------------------------------------------------------------------------
select 
    city,
    business_id,
    business_name,
    count(*) as total_reviews
from yelp_reviews_enriched
group by 1, 2, 3
qualify row_number() over (partition by city order by total_reviews desc) <= 5
order by city, total_reviews desc;

--------------------------------------------------------------------------------------------------------------------------------------------------
--8. Find the average rating of businesses that have at least 100 reviews.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Higher review count makes the average rating more statistically reliable
select 
    business_id,
    business_name,
    city,
    state,
    count(*) as total_reviews,
    round(avg(review_stars), 2) as avg_rating
from yelp_reviews_enriched
group by 1, 2, 3, 4
having count(*) >= 100
order by avg_rating desc, total_reviews desc
limit 50;   --practical output size

--------------------------------------------------------------------------------------------------------------------------------------------------
--9. List the top 10 users who have written the most reviews, along with the businesses they reviewed.
--------------------------------------------------------------------------------------------------------------------------------------------------
with top_users as (
    select 
        user_id,
        count(*) as total_reviews
    from yelp_reviews_enriched
    where user_id is not null
    group by 1
    order by 2 desc
    limit 10
)
select 
    r.user_id,
    t.total_reviews,
    r.business_id,
    r.business_name,
    r.city,
    r.state
from yelp_reviews_enriched r
inner join top_users t
    on r.user_id = t.user_id
order by t.total_reviews desc, r.user_id, r.business_name;

--------------------------------------------------------------------------------------------------------------------------------------------------
--10. Find top 10 businesses with highest positive sentiment reviews.
--------------------------------------------------------------------------------------------------------------------------------------------------
-- Includes total reviews and positive sentiment percentage for full context
with sentiment_summary as (
    select 
        business_id,
        business_name,
        city,
        state,
        count(*) as total_reviews,
        sum(case when sentiments = 'Positive' then 1 else 0 end) as positive_review_count,
        sum(case when sentiments = 'Neutral' then 1 else 0 end) as neutral_review_count,
        sum(case when sentiments = 'Negative' then 1 else 0 end) as negative_review_count,
        round(sum(case when sentiments = 'Positive' then 1 else 0 end) * 100.0 / count(*), 2) as pct_positive
    from yelp_reviews_enriched
    where user_id is not null
    group by 1, 2, 3, 4
    having count(*) >= 10
)
select 
    business_id,
    business_name,
    city,
    state,
    total_reviews,
    positive_review_count,
    neutral_review_count,
    negative_review_count,
    pct_positive
from sentiment_summary
order by positive_review_count desc
limit 10;
